{
    "name": "psc-acme/service-invoice",
    "description": "Package service-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ServiceInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/event-dispatcher": "^7.0",
        "brick/date-time": "^0.7.1",
        "illuminate/database": "^11.0",
        "symfony/symfony": "^6.3"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "vimeo/psalm": "^5.0",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}